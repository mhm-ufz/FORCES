module test_mo_netcdf_wrapper

  use funit
  use mo_kind, only : i4, i8, dp
  use mo_netcdf_wrapper, only : &
          NCW_CHUNKED, NCW_CLOBBER, NCW_DOUBLE, NCW_EEDGE, NCW_EINVAL, NCW_ERANGE, NCW_ESTRIDE, NCW_ENDIAN_BIG, NCW_ENDIAN_LITTLE, &
          NCW_FILL, NCW_FORMAT_64BIT_OFFSET, NCW_FORMAT_CLASSIC, NCW_FORMAT_NETCDF4, NCW_GLOBAL, NCW_INT, NCW_NETCDF4, &
          NCW_NOERR, NCW_NOWRITE, NCW_64BIT_OFFSET, NCW_WRITE, ncw_abort, ncw_close, ncw_copy_att, ncw_create, &
          ncw_def_dim, ncw_def_grp, ncw_def_var, ncw_def_var_chunking, ncw_def_var_deflate, ncw_def_var_endian, ncw_def_var_fill, &
          ncw_def_var_fletcher32, ncw_del_att, ncw_delete, ncw_enddef, ncw_get_att, ncw_get_var, &
          ncw_get_var64, ncw_inq_dimid, ncw_inq_dimids, ncw_inq_format, ncw_inq_grp_full_ncid, ncw_inq_grp_ncid, &
          ncw_inq_grpname_full, ncw_inq_grpname_len, ncw_inq_grps, ncw_inq_ncid, ncw_inq_path, ncw_inq_var_chunking, &
          ncw_inq_var_deflate, ncw_inq_var_endian, &
          ncw_inq_var_fletcher32, ncw_inq_var_fill, ncw_inquire, ncw_inquire_attribute, ncw_inquire_dimension, ncw_inquire_variable, &
          ncw_open, ncw_put_att, ncw_put_var, ncw_redef, ncw_rename_grp

  implicit none

  character(*), parameter :: fname_netcdf4 = "netcdf_wrapper_format_netcdf4.nc"
  character(*), parameter :: fname_classic = "netcdf_wrapper_format_classic.nc"
  character(*), parameter :: fname_64bit = "netcdf_wrapper_format_64bit.nc"
  character(*), parameter :: fname_redef = "netcdf_wrapper_redef_abort.nc"
  character(*), parameter :: fname_attrs = "netcdf_wrapper_attrs_groups.nc"
  character(*), parameter :: fname_props = "netcdf_wrapper_var_props.nc"
  character(*), parameter :: fname_scalar = "netcdf_wrapper_scalar_var.nc"
  character(*), parameter :: fname_delete = "netcdf_wrapper_delete.nc"
  character(*), parameter :: fname_standalone_props = "netcdf_wrapper_var_standalone_props.nc"
  character(*), parameter :: fname_group_listing = "netcdf_wrapper_group_listing.nc"

contains

  @test
  subroutine test_wrapper_inquire_and_path()
    integer(i4) :: status, ncid, format_num, pathlen
    character(512) :: full_path
    character(8) :: short_path

    status = ncw_create(fname_netcdf4, ior(NCW_CLOBBER, NCW_NETCDF4), ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_inq_format(ncid, format_num)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_FORMAT_NETCDF4, format_num)

    status = ncw_inquire(ncid, formatNum = format_num)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_FORMAT_NETCDF4, format_num)

    full_path = ""
    pathlen = len(full_path, kind = i4)
    status = ncw_inq_path(ncid, pathlen, full_path)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(len_trim(fname_netcdf4), pathlen)
    @assertEqual(fname_netcdf4(1:pathlen), full_path(1:pathlen))

    short_path = ""
    pathlen = len(short_path, kind = i4)
    status = ncw_inq_path(ncid, pathlen, short_path)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(min(len_trim(fname_netcdf4), len(short_path, kind = i4)), pathlen)
    @assertEqual(fname_netcdf4(1:pathlen), short_path(1:pathlen))

    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_create(fname_classic, NCW_CLOBBER, ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_inquire(ncid, formatNum = format_num)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_FORMAT_CLASSIC, format_num)
    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_create(fname_64bit, ior(NCW_CLOBBER, NCW_64BIT_OFFSET), ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_inq_format(ncid, format_num)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_FORMAT_64BIT_OFFSET, format_num)
    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_inquire_and_path

  @test
  subroutine test_wrapper_redef_enddef_and_abort()
    integer(i4) :: status, ncid, dimid

    status = ncw_create(fname_redef, NCW_CLOBBER, ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "x", 4_i4, dimid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_open(fname_redef, NCW_WRITE, ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_redef(ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "y", 7_i4, dimid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_open(fname_redef, NCW_WRITE, ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_redef(ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "z", 9_i4, dimid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_abort(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_open(fname_redef, NCW_NOWRITE, ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_inq_dimid(ncid, "y", dimid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_inq_dimid(ncid, "z", dimid)
    @assertTrue(status /= NCW_NOERR)
    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_redef_enddef_and_abort

  @test
  subroutine test_wrapper_define_scalar_variable()
    integer(i4) :: status, ncid, varid, ndims

    status = ncw_create(fname_scalar, ior(NCW_CLOBBER, NCW_NETCDF4), ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var(ncid, "scalar", NCW_DOUBLE, varid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_inquire_variable(ncid, varid, ndims = ndims)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(0_i4, ndims)

    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_define_scalar_variable

  @test
  subroutine test_wrapper_delete_file()
    integer(i4) :: status, ncid

    status = ncw_create(fname_delete, NCW_CLOBBER, ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_delete(fname_delete)
    @assertEqual(NCW_NOERR, status)
    status = ncw_open(fname_delete, NCW_NOWRITE, ncid)
    @assertTrue(status /= NCW_NOERR)
  end subroutine test_wrapper_delete_file

  @test
  subroutine test_wrapper_attribute_and_group_management()
    integer(i4) :: status, ncid, dimid, src_varid, dst_varid, grp_old, grp_new
    integer(i4) :: deleted_len
    character(32) :: copied_value

    status = ncw_create(fname_attrs, ior(NCW_CLOBBER, NCW_NETCDF4), ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "x", 3_i4, dimid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var(ncid, "source", NCW_INT, dimid, src_varid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var(ncid, "target", NCW_INT, dimid, dst_varid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_put_att(ncid, NCW_GLOBAL, "title", "forces-wrapper")
    @assertEqual(NCW_NOERR, status)
    status = ncw_put_att(ncid, src_varid, "to_delete", 7_i4)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_grp(ncid, "group_old", grp_old)
    @assertEqual(NCW_NOERR, status)
    status = ncw_rename_grp(grp_old, "group_new")
    @assertEqual(NCW_NOERR, status)
    status = ncw_copy_att(ncid, NCW_GLOBAL, "title", ncid, dst_varid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_del_att(ncid, src_varid, "to_delete")
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)

    copied_value = ""
    status = ncw_get_att(ncid, dst_varid, "title", copied_value)
    @assertEqual(NCW_NOERR, status)
    @assertEqual("forces-wrapper", trim(copied_value))

    status = ncw_inquire_attribute(ncid, src_varid, "to_delete", len = deleted_len)
    @assertTrue(status /= NCW_NOERR)

    status = ncw_inq_ncid(ncid, "group_old", grp_new)
    @assertTrue(status /= NCW_NOERR)
    status = ncw_inq_ncid(ncid, "group_new", grp_new)
    @assertEqual(NCW_NOERR, status)

    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_attribute_and_group_management

  @test
  subroutine test_wrapper_group_and_dimension_listing()
    integer(i4) :: status, ncid, grp_left, grp_right, grp_leaf, got_grp
    integer(i4) :: dim_root, dim_local, dimids(4), grpids(4), ndims, ngrps, name_len, i
    character(32) :: full_name, dim_name
    logical :: found_root_dim, found_local_dim

    status = ncw_create(fname_group_listing, ior(NCW_CLOBBER, NCW_NETCDF4), ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "root_dim", 3_i4, dim_root)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_grp(ncid, "left", grp_left)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_grp(ncid, "right", grp_right)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_grp(grp_left, "leaf", grp_leaf)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(grp_left, "local_dim", 4_i4, dim_local)
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_inq_grps(ncid, ngrps, grpids)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(2_i4, ngrps)
    @assertEqual(grp_left, grpids(1))
    @assertEqual(grp_right, grpids(2))

    status = ncw_inq_grps(grp_left, ngrps, grpids)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(1_i4, ngrps)
    @assertEqual(grp_leaf, grpids(1))

    status = ncw_inq_grp_ncid(ncid, "left", got_grp)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(grp_left, got_grp)
    status = ncw_inq_grp_full_ncid(ncid, "/left/leaf", got_grp)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(grp_leaf, got_grp)

    status = ncw_inq_grpname_len(grp_leaf, name_len)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(len_trim("/left/leaf"), name_len)
    full_name = ""
    status = ncw_inq_grpname_full(grp_leaf, name_len, full_name)
    @assertEqual(NCW_NOERR, status)
    @assertEqual("/left/leaf", full_name(1:name_len))

    status = ncw_inq_dimids(grp_left, ndims, dimids, 0_i4)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(1_i4, ndims)
    dim_name = ""
    status = ncw_inquire_dimension(grp_left, dimids(1), name = dim_name)
    @assertEqual(NCW_NOERR, status)
    @assertEqual("local_dim", trim(dim_name))

    status = ncw_inq_dimids(grp_left, ndims, dimids, 1_i4)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(2_i4, ndims)
    found_root_dim = .false.
    found_local_dim = .false.
    do i = 1, ndims
      dim_name = ""
      status = ncw_inquire_dimension(grp_left, dimids(i), name = dim_name)
      @assertEqual(NCW_NOERR, status)
      found_root_dim = found_root_dim .or. trim(dim_name) == "root_dim"
      found_local_dim = found_local_dim .or. trim(dim_name) == "local_dim"
    end do
    @assertTrue(found_root_dim)
    @assertTrue(found_local_dim)

    status = ncw_inq_dimids(grp_left, ndims, dimids(1:1), 1_i4)
    @assertEqual(NCW_EINVAL, status)

    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_group_and_dimension_listing

  @test
  subroutine test_wrapper_variable_property_inquiry()
    integer(i4) :: status, ncid, dimids(2), dimid_x, dimid_y, varid
    integer(i4) :: storage, chunksizes(2), shuffle_i, deflate_i, deflate_level
    integer(i4) :: fletcher_i, endianness, no_fill
    integer(i4) :: inq_chunks(2), inq_level, inq_endian, inq_cache_size, inq_cache_nelems, inq_cache_preemption, ndims
    logical :: contiguous, shuffle, fletcher32
    real(dp) :: fill_value, fill_in

    fill_in = -1234.5_dp
    status = ncw_create(fname_props, ior(NCW_CLOBBER, NCW_NETCDF4), ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "x", 10_i4, dimid_x)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "y", 6_i4, dimid_y)
    @assertEqual(NCW_NOERR, status)
    dimids = [dimid_x, dimid_y]
    status = ncw_def_var(ncid, "data", NCW_DOUBLE, dimids, varid, chunksizes = [4_i4, 2_i4], deflate_level = 3_i4, shuffle = .true., &
            fletcher32 = .true., endianness = NCW_ENDIAN_LITTLE, cache_size = 8192_i4, cache_nelems = 64_i4, cache_preemption = 60_i4)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var_fill(ncid, varid, NCW_FILL, fill_in)
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_inq_var_chunking(ncid, varid, storage, chunksizes)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_CHUNKED, storage)
    @assertEqual([4_i4, 2_i4], chunksizes)

    status = ncw_inq_var_deflate(ncid, varid, shuffle_i, deflate_i, deflate_level)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(1_i4, shuffle_i)
    @assertEqual(1_i4, deflate_i)
    @assertEqual(3_i4, deflate_level)

    status = ncw_inq_var_fletcher32(ncid, varid, fletcher_i)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(1_i4, fletcher_i)

    status = ncw_inq_var_endian(ncid, varid, endianness)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_ENDIAN_LITTLE, endianness)

    status = ncw_inq_var_fill(ncid, varid, no_fill, fill_value)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_FILL, no_fill)
    @assertEqual(fill_in, fill_value)

    status = ncw_inquire_variable(ncid, varid, ndims = ndims, contiguous = contiguous, chunksizes = inq_chunks, deflate_level = inq_level, &
            shuffle = shuffle, fletcher32 = fletcher32, endianness = inq_endian, cache_size = inq_cache_size, &
            cache_nelems = inq_cache_nelems, cache_preemption = inq_cache_preemption)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(2_i4, ndims)
    @assertFalse(contiguous)
    @assertEqual([4_i4, 2_i4], inq_chunks)
    @assertEqual(3_i4, inq_level)
    @assertTrue(shuffle)
    @assertTrue(fletcher32)
    @assertEqual(NCW_ENDIAN_LITTLE, inq_endian)
    @assertEqual(8192_i4, inq_cache_size)
    @assertEqual(64_i4, inq_cache_nelems)
    @assertEqual(60_i4, inq_cache_preemption)

    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_variable_property_inquiry

  @test
  subroutine test_wrapper_standalone_variable_property_definition()
    integer(i4) :: status, ncid, dimids(2), varid
    integer(i4) :: storage, chunksizes(2), shuffle_i, deflate_i, deflate_level
    integer(i4) :: fletcher_i, endianness

    status = ncw_create(fname_standalone_props, ior(NCW_CLOBBER, NCW_NETCDF4), ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "x", 10_i4, dimids(1))
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "y", 6_i4, dimids(2))
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var(ncid, "data", NCW_DOUBLE, dimids, varid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_def_var_chunking(ncid, varid, NCW_CHUNKED, [5_i4])
    @assertEqual(NCW_EINVAL, status)
    status = ncw_def_var_chunking(ncid, varid, NCW_CHUNKED, [5_i4, 3_i4])
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var_deflate(ncid, varid, 1_i4, 1_i4, 2_i4)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var_fletcher32(ncid, varid, 1_i4)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var_endian(ncid, varid, NCW_ENDIAN_BIG)
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_inq_var_chunking(ncid, varid, storage, chunksizes)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_CHUNKED, storage)
    @assertEqual([5_i4, 3_i4], chunksizes)

    status = ncw_inq_var_deflate(ncid, varid, shuffle_i, deflate_i, deflate_level)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(1_i4, shuffle_i)
    @assertEqual(1_i4, deflate_i)
    @assertEqual(2_i4, deflate_level)

    status = ncw_inq_var_fletcher32(ncid, varid, fletcher_i)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(1_i4, fletcher_i)

    status = ncw_inq_var_endian(ncid, varid, endianness)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(NCW_ENDIAN_BIG, endianness)

    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_standalone_variable_property_definition

  @test
  subroutine test_wrapper_slice_validation()
    use, intrinsic :: iso_c_binding, only : c_ptrdiff_t, c_size_t

    integer(i4) :: status, ncid, dimid, varid
    integer(i4) :: write_buf(2), read_buf(2)
    integer(i8) :: bad_value(1)

    write_buf = [10_i4, 20_i4]
    read_buf = -1_i4

    status = ncw_create("netcdf_wrapper_slice_validation.nc", ior(NCW_CLOBBER, NCW_NETCDF4), ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "x", 4_i4, dimid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var(ncid, "data", NCW_INT, dimid, varid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_put_var(ncid, varid, write_buf, start = [1_i4], cnt = [3_i4])
    @assertEqual(NCW_EEDGE, status)

    status = ncw_put_var(ncid, varid, write_buf, start = [0_i4], cnt = [2_i4])
    @assertEqual(NCW_EINVAL, status)

    status = ncw_get_var(ncid, varid, read_buf, start = [1_i4], cnt = [2_i4], stride = [0_i4])
    @assertEqual(NCW_ESTRIDE, status)

    if (int(storage_size(0_c_size_t), i4) < int(storage_size(0_i8), i4)) then
      bad_value = [huge(0_i8)]
      status = ncw_get_var64(ncid, varid, read_buf, cnt = bad_value)
      @assertEqual(NCW_ERANGE, status)
    else if (int(storage_size(0_c_ptrdiff_t), i4) < int(storage_size(0_i8), i4)) then
      bad_value = [huge(0_i8)]
      status = ncw_get_var64(ncid, varid, read_buf, stride = bad_value)
      @assertEqual(NCW_ERANGE, status)
    else
      @assertTrue(.true.)
    end if

    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_slice_validation

  @test
  subroutine test_wrapper_oversized_slice_vectors()
    integer(i4), parameter :: nx = 4_i4, ny = 3_i4, nz = 2_i4
    integer(i4), parameter :: start_full(5) = [1_i4, 1_i4, 1_i4, 1_i4, 1_i4]
    integer(i4), parameter :: cnt_full(5) = [nx, ny, nz, 1_i4, 1_i4]
    integer(i4), parameter :: start_slab(5) = [1_i4, 1_i4, 2_i4, 1_i4, 1_i4]
    integer(i4), parameter :: cnt_slab(5) = [nx, ny, 1_i4, 1_i4, 1_i4]

    integer(i4) :: status, ncid, dimids(3), varid
    integer(i4) :: base(nx, ny, nz), full_read(nx, ny, nz)
    integer(i4) :: slab(nx, ny), slab_read(nx, ny)
    integer(i4) :: i

    base = reshape([(i, i = 1, size(base))], shape(base))
    slab = 1000_i4 + reshape([(i, i = 1, size(slab))], shape(slab))
    full_read = -1_i4
    slab_read = -1_i4

    status = ncw_create("netcdf_wrapper_oversized_slices.nc", ior(NCW_CLOBBER, NCW_NETCDF4), ncid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "x", nx, dimids(1))
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "y", ny, dimids(2))
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_dim(ncid, "z", nz, dimids(3))
    @assertEqual(NCW_NOERR, status)
    status = ncw_def_var(ncid, "data", NCW_INT, dimids, varid)
    @assertEqual(NCW_NOERR, status)
    status = ncw_enddef(ncid)
    @assertEqual(NCW_NOERR, status)

    status = ncw_put_var(ncid, varid, base, start = start_full, cnt = cnt_full)
    @assertEqual(NCW_NOERR, status)
    status = ncw_get_var(ncid, varid, full_read, start = start_full, cnt = cnt_full)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(base, full_read)

    status = ncw_put_var(ncid, varid, slab, start = start_slab, cnt = cnt_slab)
    @assertEqual(NCW_NOERR, status)
    status = ncw_get_var(ncid, varid, slab_read, start = start_slab, cnt = cnt_slab)
    @assertEqual(NCW_NOERR, status)
    @assertEqual(slab, slab_read)

    status = ncw_get_var(ncid, varid, full_read, start = [1_i4, 1_i4, 1_i4, 0_i4, 1_i4], cnt = cnt_full)
    @assertEqual(NCW_EINVAL, status)
    status = ncw_get_var(ncid, varid, full_read, start = start_full, cnt = [nx, ny, nz, 2_i4, 1_i4])
    @assertEqual(NCW_EEDGE, status)
    status = ncw_get_var(ncid, varid, full_read, start = start_full, cnt = cnt_full, &
            stride = [1_i4, 1_i4, 1_i4, 2_i4, 1_i4])
    @assertEqual(NCW_ESTRIDE, status)

    status = ncw_close(ncid)
    @assertEqual(NCW_NOERR, status)
  end subroutine test_wrapper_oversized_slice_vectors

end module test_mo_netcdf_wrapper
