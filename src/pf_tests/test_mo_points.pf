module test_mo_points
  use funit
  use mo_kind, only: i1, i2, i4, i8, dp, sp
  use mo_grid, only: grid_t, cartesian, spherical, bottom_up
  use mo_netcdf, only: NcDataset, NcVariable, NcDimension
  use mo_points, only: points_t
  use mo_points_io, only: add_var, var, points_output_dataset, points_series_output_dataset, points_input_dataset, &
                          points_time_axis, points_id_index, points_id_indices
  use mo_grid_io, only: daily, hourly, start_timestamp, center_timestamp, end_timestamp
  use mo_points_regridder, only: nearest_grid_to_points_t, nearest_points_to_grid_t, nearest_points_to_points_t
  use mo_datetime, only: datetime
  use mo_timeseries, only: time_t
  implicit none

  private

  public :: test_read_scc_gauges
  public :: test_points_netcdf_roundtrip
  public :: test_points_output_input
  public :: test_points_time_series_io
  public :: test_points_time_axis_and_ids
  public :: test_nearest_regridding

contains

  @test
  subroutine test_read_scc_gauges()
    type(points_t), target :: points
    type(points_input_dataset) :: inp
    type(var), allocatable :: input_vars(:)
    integer(i4), allocatable :: ids(:)

    call points%from_netcdf("files/scc_gauges.nc", var="station")

    @assertEqual(points%coordsys, cartesian)
    @assertEqual(points%n_points, 3_i8)
    @assertEqual(size(points%x, kind=i8), 3_i8)
    @assertEqual(size(points%y, kind=i8), 3_i8)

    allocate(input_vars(0))
    call inp%init("files/scc_gauges.nc", vars=input_vars, points=points, points_init_var="station")
    call inp%get_ids(ids)
    call inp%close()
    @assertTrue(all(ids == [1_i4, 2_i4, 3_i4]))
  end subroutine test_read_scc_gauges

  @test
  subroutine test_points_netcdf_roundtrip()
    type(points_t) :: cart_points, sph_points, cart_read, sph_read
    type(NcDataset) :: nc
    type(NcVariable) :: var
    character(len=256) :: attr

    call cart_points%init([1.0_dp, 2.0_dp], [3.0_dp, 4.0_dp], coordsys=cartesian)
    call cart_points%to_netcdf("points_cart.nc")
    call cart_read%from_netcdf("points_cart.nc")
    @assertEqual(cart_read%coordsys, cartesian)
    @assertTrue(cart_read%is_matching(cart_points))
    @assertEqual(cart_read%x, cart_points%x, tolerance=1.0e-12_dp)
    @assertEqual(cart_read%y, cart_points%y, tolerance=1.0e-12_dp)

    call cart_read%init([1.0_dp + 1.0e-8_dp, 2.0_dp], [3.0_dp, 4.0_dp], coordsys=cartesian)
    @assertTrue(cart_read%is_matching(cart_points))
    @assertFalse(cart_read%is_matching(cart_points, tol=1.0e-10_dp))

    nc = NcDataset("points_cart.nc", "r")
    var = nc%getVariable("x")
    call var%getAttribute("standard_name", attr)
    @assertEqual(trim(attr), "projection_x_coordinate")
    call nc%close()

    call sph_points%init([10.0_dp, 11.0_dp], [50.0_dp, 51.0_dp], coordsys=spherical)
    call sph_points%to_netcdf("points_spherical.nc")
    call sph_read%from_netcdf("points_spherical.nc")
    @assertEqual(sph_read%coordsys, spherical)
    @assertEqual(sph_read%x, sph_points%x, tolerance=1.0e-12_dp)
    @assertEqual(sph_read%y, sph_points%y, tolerance=1.0e-12_dp)
    nc = NcDataset("points_spherical.nc", "r")
    var = nc%getVariable("lon")
    call var%getAttribute("standard_name", attr)
    @assertEqual(trim(attr), "longitude")
    call nc%close()
  end subroutine test_points_netcdf_roundtrip

  @test
  subroutine test_points_output_input()
    type(points_t), target :: points, points_read
    type(points_output_dataset) :: out
    type(points_input_dataset) :: inp
    type(time_t) :: time_axis
    type(var), allocatable :: vars(:)
    type(var), allocatable :: static_vars(:)
    real(dp) :: values(3), read_values(3)
    real(dp), allocatable :: read_chunk(:, :)
    real(sp) :: values_sp(3), read_sp(3)
    integer(i1) :: values_i1(3), read_i1(3)
    integer(i2) :: values_i2(3), read_i2(3)
    integer(i4) :: values_i4(3), read_i4(3)
    integer(i8) :: values_i8(3), read_i8(3)
    integer(i4), allocatable :: ids_i4(:)
    integer(i8), allocatable :: ids_i8(:)
    type(datetime) :: start_time, expected_time
    type(datetime), allocatable :: times(:)

    call points%init([1.0_dp, 2.0_dp, 3.0_dp], [4.0_dp, 5.0_dp, 6.0_dp], coordsys=cartesian)
    allocate(vars(0))
    call add_var(vars, var(name="discharge", units="m3 s-1", static=.false., dtype="f64", kind="dp"))

    start_time = datetime("1990-01-01")
    call out%init("point_discharge.nc", points=points, vars=vars, start_time=start_time, point_dim_name="node")
    values = [10.0_dp, 20.0_dp, 30.0_dp]
    call out%update("discharge", values)
    call out%write(datetime("1990-01-02"))
    call out%close()

    call points_read%from_netcdf("point_discharge.nc", var="discharge")
    @assertEqual(points_read%n_points, 3_i8)
    @assertEqual(points_read%x, points%x, tolerance=1.0e-12_dp)
    call inp%init("point_discharge.nc", vars=vars, points=points_read)
    time_axis = inp%time_axis()
    @assertEqual(time_axis%n_times(), 1_i4)
    @assertEqual(time_axis%values, [1_i4])
    @assertEqual(time_axis%bounds(:, 1_i4), [0_i4, 1_i4])
    call inp%read("discharge", read_values, current_time=datetime("1990-01-02"))
    @assertEqual(read_values, values, tolerance=1.0e-12_dp)
    call inp%read_chunk("discharge", read_chunk, datetime("1990-01-01"), datetime("1990-01-02"), times)
    call inp%close()
    @assertEqual(shape(read_chunk), [3_i4, 1_i4])
    @assertEqual(read_chunk(:, 1), values, tolerance=1.0e-12_dp)
    @assertEqual(size(times), 1)
    expected_time = datetime("1990-01-02")
    @assertEqual(times(1)%str(), expected_time%str())

    allocate(static_vars(0))
    call add_var(static_vars, var(name="height_sp", static=.true., dtype="f32", kind="sp"))
    call add_var(static_vars, var(name="code_i1", static=.true., dtype="i8", kind="i1"))
    call add_var(static_vars, var(name="code_i2", static=.true., dtype="i16", kind="i2"))
    call add_var(static_vars, var(name="code_i4", static=.true., dtype="i32", kind="i4"))
    call add_var(static_vars, var(name="code_i8", static=.true., dtype="i64", kind="i8"))
    call out%init("point_static_kinds.nc", points=points, vars=static_vars)
    values_sp = [1.0_sp, 2.0_sp, 3.0_sp]
    values_i1 = [1_i1, 2_i1, 3_i1]
    values_i2 = [10_i2, 20_i2, 30_i2]
    values_i4 = [100_i4, 200_i4, 300_i4]
    values_i8 = [1000_i8, 2000_i8, 3000_i8]
    call out%update("height_sp", values_sp)
    call out%update("code_i1", values_i1)
    call out%update("code_i2", values_i2)
    call out%update("code_i4", values_i4)
    call out%update("code_i8", values_i8)
    call out%write_static()
    call out%close()

    call inp%init("point_static_kinds.nc", vars=static_vars, points=points)
    call inp%read("height_sp", read_sp)
    call inp%read("code_i1", read_i1)
    call inp%read("code_i2", read_i2)
    call inp%read("code_i4", read_i4)
    call inp%read("code_i8", read_i8)
    call inp%get_ids(ids_i4, id_name="code_i4")
    call inp%get_ids(ids_i8)
    call inp%close()
    @assertEqual(read_sp, values_sp, tolerance=1.0e-6_sp)
    @assertTrue(all(read_i1 == values_i1))
    @assertTrue(all(read_i2 == values_i2))
    @assertTrue(all(read_i4 == values_i4))
    @assertTrue(all(read_i8 == values_i8))
    @assertTrue(all(ids_i4 == values_i4))
    @assertTrue(all(ids_i8 == [1_i8, 2_i8, 3_i8]))
  end subroutine test_points_output_input

  @test
  subroutine test_points_time_series_io()
    type(points_t), target :: points, points_read
    type(points_output_dataset) :: out
    type(points_series_output_dataset) :: series_out
    type(points_input_dataset) :: inp
    type(var), allocatable :: vars(:)
    type(var), allocatable :: mixed_vars(:)
    type(NcDataset) :: nc
    type(NcVariable) :: nc_var, time_var, bnds_var
    type(NcDimension) :: node_dim, time_dim, bnds_dim
    type(NcDimension), allocatable :: dims(:)
    type(time_t) :: time_axis
    real(dp) :: values_1(3), values_2(3), read_values(3)
    real(dp), allocatable :: read_chunk(:, :), read_series(:)
    real(dp) :: slice_data(3, 2), series_data(2, 3)
    integer(i4) :: codes_1(3), codes_2(3), station_ids(3)
    integer(i4), allocatable :: read_codes(:), read_station_ids(:)
    integer(i4) :: tvals(2), tbnds(2, 2)
    character(len=64) :: dim_name
    type(datetime), allocatable :: times(:)

    call points%init([1.0_dp, 2.0_dp, 3.0_dp], [4.0_dp, 5.0_dp, 6.0_dp], coordsys=cartesian)
    allocate(vars(0))
    call add_var(vars, var(name="discharge", units="m3 s-1", static=.false., dtype="f64", kind="dp"))

    call out%init("point_discharge_series_layout.nc", points=points, vars=vars, start_time=datetime("1990-01-01"), &
                  point_dim_name="node", time_series=.true.)
    values_1 = [10.0_dp, 20.0_dp, 30.0_dp]
    values_2 = [11.0_dp, 21.0_dp, 31.0_dp]
    call out%update("discharge", values_1)
    call out%write(datetime("1990-01-02"))
    call out%update("discharge", values_2)
    call out%write(datetime("1990-01-03"))
    call out%close()

    nc = NcDataset("point_discharge_series_layout.nc", "r")
    nc_var = nc%getVariable("discharge")
    dims = nc_var%getDimensions()
    dim_name = dims(1)%getName()
    @assertEqual(trim(dim_name), "time")
    dim_name = dims(2)%getName()
    @assertEqual(trim(dim_name), "node")
    call nc%close()

    call points_read%from_netcdf("point_discharge_series_layout.nc", var="discharge")
    call inp%init("point_discharge_series_layout.nc", vars=vars, points=points_read)
    call inp%read("discharge", read_values, current_time=datetime("1990-01-02"))
    @assertEqual(read_values, values_1, tolerance=1.0e-12_dp)
    call inp%read_chunk("discharge", read_chunk, datetime("1990-01-01"), datetime("1990-01-03"))
    @assertEqual(shape(read_chunk), [3_i4, 2_i4])
    @assertEqual(read_chunk(:, 2), values_2, tolerance=1.0e-12_dp)
    call inp%read_series("discharge", 2_i8, read_series, times=times)
    call inp%close()
    @assertEqual(read_series, [20.0_dp, 21.0_dp], tolerance=1.0e-12_dp)
    @assertEqual(size(times), 2)

    tvals = [1_i4, 2_i4]
    tbnds(:, 1) = [0_i4, 1_i4]
    tbnds(:, 2) = [1_i4, 2_i4]
    allocate(mixed_vars(0))
    call add_var(mixed_vars, var(name="station", static=.true., dtype="i32", kind="i4"))
    call add_var(mixed_vars, var(name="discharge", units="m3 s-1", static=.false., dtype="f64", kind="dp"))
    call add_var(mixed_vars, var(name="code", static=.false., dtype="i32", kind="i4"))
    call series_out%init("point_series_writer.nc", points=points, vars=mixed_vars, time_values=tvals, &
                         time_units="days since 1990-01-01 00:00:00", time_bnds=tbnds, point_dim_name="station")
    station_ids = [101_i4, 102_i4, 103_i4]
    call series_out%write_static("station", station_ids)
    call series_out%write_series("discharge", 1_i8, [100.0_dp, 101.0_dp])
    call series_out%write_series("discharge", 2_i8, [200.0_dp, 201.0_dp])
    call series_out%write_series("discharge", 3_i8, [300.0_dp, 301.0_dp])
    codes_1 = [1_i4, 2_i4, 3_i4]
    codes_2 = [4_i4, 5_i4, 6_i4]
    call series_out%write_series("code", 1_i8, [codes_1(1), codes_2(1)])
    call series_out%write_series("code", 2_i8, [codes_1(2), codes_2(2)])
    call series_out%write_series("code", 3_i8, [codes_1(3), codes_2(3)])
    call series_out%close()

    call inp%init("point_series_writer.nc", vars=mixed_vars, points=points)
    time_axis = inp%time_axis()
    @assertEqual(time_axis%values, tvals)
    @assertEqual(time_axis%bounds, tbnds)
    @assertEqual(trim(time_axis%units), "days since 1990-01-01 00:00:00")
    call inp%read_series("discharge", 3_i8, read_series)
    @assertEqual(read_series, [300.0_dp, 301.0_dp], tolerance=1.0e-12_dp)
    call inp%read_series("code", 2_i8, read_codes)
    @assertTrue(all(read_codes == [2_i4, 5_i4]))
    call inp%get_ids(read_station_ids)
    @assertTrue(all(read_station_ids == station_ids))
    call inp%close()

    nc = NcDataset("point_mixed_layout.nc", "w")
    call points%to_netcdf(nc, point_dim_name="node")
    node_dim = nc%getDimension("node")
    time_dim = nc%setDimension("time", 2_i4)
    bnds_dim = nc%setDimension("bnds", 2_i4)
    time_var = nc%setVariable("time", "i32", [time_dim])
    call time_var%setAttribute("standard_name", "time")
    call time_var%setAttribute("axis", "T")
    call time_var%setAttribute("units", "days since 1990-01-01 00:00:00")
    call time_var%setAttribute("bounds", "time_bnds")
    call time_var%setData(tvals)
    bnds_var = nc%setVariable("time_bnds", "i32", [bnds_dim, time_dim])
    call bnds_var%setData(tbnds)
    nc_var = nc%setVariable("slice", "f64", [node_dim, time_dim])
    call nc_var%setAttribute("coordinates", "x y")
    slice_data(:, 1) = [1.0_dp, 2.0_dp, 3.0_dp]
    slice_data(:, 2) = [4.0_dp, 5.0_dp, 6.0_dp]
    call nc_var%setData(slice_data)
    nc_var = nc%setVariable("series", "f64", [time_dim, node_dim])
    call nc_var%setAttribute("coordinates", "x y")
    series_data(1, :) = [10.0_dp, 20.0_dp, 30.0_dp]
    series_data(2, :) = [11.0_dp, 21.0_dp, 31.0_dp]
    call nc_var%setData(series_data)
    call nc%close()

    deallocate(mixed_vars)
    allocate(mixed_vars(0))
    call add_var(mixed_vars, var(name="slice", static=.false., dtype="f64", kind="dp"))
    call add_var(mixed_vars, var(name="series", static=.false., dtype="f64", kind="dp"))
    call inp%init("point_mixed_layout.nc", vars=mixed_vars, points=points)
    call inp%read("slice", read_values, current_time=datetime("1990-01-03"))
    @assertEqual(read_values, slice_data(:, 2), tolerance=1.0e-12_dp)
    call inp%read("series", read_values, current_time=datetime("1990-01-02"))
    @assertEqual(read_values, series_data(1, :), tolerance=1.0e-12_dp)
    call inp%read_series("series", 2_i8, read_series)
    @assertEqual(read_series, [20.0_dp, 21.0_dp], tolerance=1.0e-12_dp)
    call inp%close()
  end subroutine test_points_time_series_io

  @test
  subroutine test_points_time_axis_and_ids()
    integer(i4), allocatable :: values(:), bounds(:, :)
    integer(i8) :: idx
    integer(i8) :: indices(2)
    character(:), allocatable :: units

    call points_time_axis(datetime("1990-01-01"), datetime("1990-01-03"), values, bounds, units, &
                          timestep=daily, timestamp=end_timestamp)
    @assertEqual(values, [1_i4, 2_i4])
    @assertEqual(bounds(:, 1), [0_i4, 1_i4])
    @assertEqual(trim(units), "days since 1990-01-01 00:00:00")

    call points_time_axis(datetime("1990-01-01"), datetime("1990-01-01 02:00:00"), values, bounds, units, &
                          timestep=hourly, timestamp=center_timestamp)
    @assertEqual(values, [30_i4, 90_i4])
    @assertEqual(bounds(:, 2), [60_i4, 120_i4])
    @assertEqual(trim(units), "minutes since 1990-01-01 00:00:00")

    call points_time_axis(datetime("1990-01-01"), datetime("1990-01-03"), values, bounds, units, &
                          timestep=daily, timestamp=start_timestamp, ref_time=datetime("1989-12-31"))
    @assertEqual(values, [1_i4, 2_i4])
    @assertEqual(trim(units), "days since 1989-12-31 00:00:00")

    idx = points_id_index([11_i4, 22_i4, 33_i4], 22_i4)
    @assertEqual(idx, 2_i8)
    indices = points_id_indices([11_i8, 22_i8, 33_i8], [33_i8, 11_i8])
    @assertEqual(indices, [3_i8, 1_i8])
  end subroutine test_points_time_axis_and_ids

  @test
  subroutine test_nearest_regridding()
    type(grid_t), target :: grid
    type(points_t), target :: target_points, source_points, target_points_2
    type(nearest_grid_to_points_t) :: grid_to_points
    type(nearest_points_to_grid_t) :: points_to_grid
    type(nearest_points_to_points_t) :: points_to_points
    real(dp) :: grid_data(4), point_data(3), out_points(3), out_grid(4), out_points_2(2)

    call grid%init(nx=2_i4, ny=2_i4, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                   coordsys=cartesian, y_direction=bottom_up)
    call target_points%init([0.45_dp, 1.45_dp, 0.45_dp], [0.45_dp, 0.45_dp, 1.45_dp], coordsys=cartesian)
    grid_data = [1.0_dp, 2.0_dp, 3.0_dp, 4.0_dp]
    call grid_to_points%init(source_grid=grid, target_points=target_points)
    call grid_to_points%execute(grid_data, out_points)
    @assertEqual(out_points, [1.0_dp, 2.0_dp, 3.0_dp], tolerance=1.0e-12_dp)

    call source_points%init([0.0_dp, 2.0_dp, 4.0_dp], [0.0_dp, 0.0_dp, 0.0_dp], coordsys=cartesian)
    call target_points_2%init([0.2_dp, 3.6_dp], [0.0_dp, 0.0_dp], coordsys=cartesian)
    point_data = [5.0_dp, 6.0_dp, 7.0_dp]
    call points_to_points%init(source_points=source_points, target_points=target_points_2)
    call points_to_points%execute(point_data, out_points_2)
    @assertEqual(out_points_2, [5.0_dp, 7.0_dp], tolerance=1.0e-12_dp)

    call points_to_grid%init(source_points=source_points, target_grid=grid)
    call points_to_grid%execute(point_data, out_grid)
    @assertEqual(out_grid, [5.0_dp, 6.0_dp, 5.0_dp, 6.0_dp], tolerance=1.0e-12_dp)
  end subroutine test_nearest_regridding

end module test_mo_points
