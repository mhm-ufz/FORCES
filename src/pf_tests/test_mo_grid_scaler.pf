module test_mo_grid_scaler
  use funit
  use mo_grid, only: grid_t, cartesian, spherical, top_down, bottom_up
  use mo_grid_scaler, only: scaler_t, nearest_regridder_t, up_a_mean, up_h_mean, up_p_mean, up_min, up_max, up_sum, &
                            up_laf, up_fraction, up_median, down_nearest, down_split
  use mo_kind, only: i4, dp, i8
  use mo_utils, only: flip, flipped, is_close
  use mo_constants, only: nodata_dp
  ! use mo_netcdf, only: NcDataset, NcVariable, NcDimension
  implicit none

  private

  public :: test_regrid
  public :: test_downscale_modes
  public :: test_no_scaling_identity
  public :: test_stats_and_weight_count
  public :: test_median_masked
  public :: test_laf_masked_direct_and_packed
  public :: test_nearest_regridder_cartesian
  public :: test_nearest_regridder_masked_and_aux
  public :: test_nearest_regridder_spherical_and_mixed
  public :: test_nearest_regridder_derived_mask_cartesian
  public :: test_nearest_regridder_derived_mask_spherical_aux

contains

  @test
  subroutine test_regrid()

    implicit none
    type(grid_t), target :: cgrid, fgrid
    type(scaler_t) :: upscaler
    ! type(NcDataset) :: nc
    ! type(NcDimension) :: x_dim, y_dim
    ! type(NcVariable) :: var
    real(dp) :: t=1.0E-5_dp
    real(dp) :: ref_val
    integer(i4) :: xt, xb, yt, yb
    integer(i8) :: i
    real(dp), allocatable :: dem(:), dem_mat(:,:), cdem(:), cdem_mat(:,:), weights(:), cweights(:)
    integer(i4), allocatable :: lc(:), clc(:), lc_mat(:,:), clc_mat(:,:)
    real(dp), allocatable :: lc1(:), lc2(:), lc3(:), lcf_mat(:,:)

    call fgrid%from_ascii_file("./files/dem.asc")
    cgrid = fgrid%derive_grid(upscaling_factor=16)

    call upscaler%init(fgrid, cgrid)

    allocate(weights(fgrid%ncells))
    weights = fgrid%pack(upscaler%weights)
    allocate(cweights(cgrid%ncells))
    call upscaler%execute(weights, cweights, upscaling_operator=up_sum)
    @assertTrue(all(is_close(cweights, 1.0_dp)), message='check weights sum to 1')

    call fgrid%read_data("./files/dem.asc", dem_mat)
    call fgrid%read_data("./files/landcover.asc", lc_mat)

    ! nc = NcDataset("dem.nc", "w")
    ! call fgrid%to_netcdf(nc)
    ! x_dim = nc%getDimension("x")
    ! y_dim = nc%getDimension("y")
    ! var = nc%setVariable("dem", "f64", [x_dim, y_dim])
    ! call var%setFillValue(nodata_dp)
    ! call var%setAttribute("missing_value", nodata_dp)
    ! call var%setData(dem_mat)
    ! call nc%close()

    allocate(dem(fgrid%ncells))
    dem = fgrid%pack(dem_mat)
    allocate(cdem(cgrid%ncells))
    allocate(cdem_mat(cgrid%nx, cgrid%ny))

    ! nc = NcDataset("cdem.nc", "w")
    ! call cgrid%to_netcdf(nc)
    ! x_dim = nc%getDimension("x")
    ! y_dim = nc%getDimension("y")

    @assertEqual(cgrid%nx, 18, message='upscaling nx check')
    @assertEqual(cgrid%ny, 27, message='upscaling ny check')

    call upscaler%execute(dem, cdem)
    ! check arithmetic mean upscaling
    do i = 1_i8, cgrid%ncells
      call upscaler%coarse_bounds(i, xb, xt, yb, yt)
      ! cartesian grid can use n-subcells for weights
      ref_val = sum(pack(dem_mat(xb:xt,yb:yt), fgrid%mask(xb:xt,yb:yt))) / upscaler%n_subcells(i)
      @assertEqual(cdem(i), ref_val, tolerance=t, message='upscaling arithmetic mean check')
    end do

    ! var = nc%setVariable("dem_mean", "f64", [x_dim, y_dim])
    ! call var%setFillValue(nodata_dp)
    ! call var%setAttribute("missing_value", nodata_dp)
    ! cdem_mat = cgrid%unpack(cdem)
    ! call var%setData(cdem_mat)

    call upscaler%execute(dem, cdem, upscaling_operator=up_p_mean, p=2.1_dp)
    ! check p-mean upscaling
    do i = 1_i8, cgrid%ncells
      call upscaler%coarse_bounds(i, xb, xt, yb, yt)
      ! cartesian grid can use n-subcells for weights
      ref_val = (sum(pack(dem_mat(xb:xt,yb:yt), fgrid%mask(xb:xt,yb:yt)) ** 2.1_dp) / upscaler%n_subcells(i)) ** (1.0_dp / 2.1_dp)
      @assertEqual(cdem(i), ref_val, tolerance=t, message='upscaling p-mean check (p=2.1)')
    end do

    ! var = nc%setVariable("dem_pmean", "f64", [x_dim, y_dim])
    ! call var%setFillValue(nodata_dp)
    ! call var%setAttribute("missing_value", nodata_dp)
    ! cdem_mat = cgrid%unpack(cdem)
    ! call var%setData(cdem_mat)

    call upscaler%execute(dem, cdem, upscaling_operator=up_p_mean, p=0.0_dp)
    ! check g-mean upscaling
    do i = 1_i8, cgrid%ncells
      call upscaler%coarse_bounds(i, xb, xt, yb, yt)
      ! cartesian grid can use n-subcells for weights
      ref_val = exp(sum(log(pack(dem_mat(xb:xt,yb:yt), fgrid%mask(xb:xt,yb:yt)))) / upscaler%n_subcells(i))
      @assertEqual(cdem(i), ref_val, tolerance=t, message='upscaling geometric mean check')
    end do

    ! var = nc%setVariable("dem_gmean", "f64", [x_dim, y_dim])
    ! call var%setFillValue(nodata_dp)
    ! call var%setAttribute("missing_value", nodata_dp)
    ! cdem_mat = cgrid%unpack(cdem)
    ! call var%setData(cdem_mat)

    call upscaler%execute(dem, cdem, upscaling_operator=up_h_mean)
    ! check h-mean upscaling
    do i = 1_i8, cgrid%ncells
      call upscaler%coarse_bounds(i, xb, xt, yb, yt)
      ! cartesian grid can use n-subcells for weights
      ref_val = 1.0_dp / (sum(1.0 / pack(dem_mat(xb:xt,yb:yt), fgrid%mask(xb:xt,yb:yt))) / upscaler%n_subcells(i))
      @assertEqual(cdem(i), ref_val, tolerance=t, message='upscaling harmonic mean check')
    end do

    ! var = nc%setVariable("dem_hmean", "f64", [x_dim, y_dim])
    ! call var%setFillValue(nodata_dp)
    ! call var%setAttribute("missing_value", nodata_dp)
    ! cdem_mat = cgrid%unpack(cdem)
    ! call var%setData(cdem_mat)

    call upscaler%execute(dem, cdem, upscaling_operator=up_min)
    ! check min upscaling
    do i = 1_i8, cgrid%ncells
      call upscaler%coarse_bounds(i, xb, xt, yb, yt)
      ! cartesian grid can use n-subcells for weights
      ref_val = minval(dem_mat(xb:xt,yb:yt), mask=fgrid%mask(xb:xt,yb:yt))
      @assertEqual(cdem(i), ref_val, tolerance=t, message='upscaling min check')
    end do

    ! var = nc%setVariable("dem_min", "f64", [x_dim, y_dim])
    ! call var%setFillValue(nodata_dp)
    ! call var%setAttribute("missing_value", nodata_dp)
    ! cdem_mat = cgrid%unpack(cdem)
    ! call var%setData(cdem_mat)

    call upscaler%execute(dem, cdem, upscaling_operator=up_max)
    ! check max upscaling
    do i = 1_i8, cgrid%ncells
      call upscaler%coarse_bounds(i, xb, xt, yb, yt)
      ! cartesian grid can use n-subcells for weights
      ref_val = maxval(dem_mat(xb:xt,yb:yt), mask=fgrid%mask(xb:xt,yb:yt))
      @assertEqual(cdem(i), ref_val, tolerance=t, message='upscaling max check')
    end do

    ! var = nc%setVariable("dem_max", "f64", [x_dim, y_dim])
    ! call var%setFillValue(nodata_dp)
    ! call var%setAttribute("missing_value", nodata_dp)
    ! cdem_mat = cgrid%unpack(cdem)
    ! call var%setData(cdem_mat)

    allocate(lc(fgrid%ncells))
    lc = fgrid%pack(lc_mat)
    allocate(clc(cgrid%ncells))
    allocate(lc1(cgrid%ncells))
    allocate(lc2(cgrid%ncells))
    allocate(lc3(cgrid%ncells))
    call upscaler%execute(lc, clc, upscaling_operator=up_laf, vmin=1_i4, vmax=3_i4)
    call upscaler%execute(lc, lc1, upscaling_operator=up_fraction, class_id=1_i4)
    call upscaler%execute(lc, lc2, upscaling_operator=up_fraction, class_id=2_i4)
    call upscaler%execute(lc, lc3, upscaling_operator=up_fraction, class_id=3_i4)

    @assertTrue(all(is_close(lc1+lc2+lc3, 1.0_dp)), message='check fractions sum to 1')
    @assertEqual(count(clc==1)+count(clc==2)+count(clc==3), cgrid%ncells, message='check fraction counts')

    ! call nc%close()

  end subroutine test_regrid

  @test
  subroutine test_downscale_modes()
    implicit none
    type(grid_t), target :: coarse, fine
    type(scaler_t) :: scaler
    real(dp), allocatable :: dp_out(:)
    integer(i4), allocatable :: i_out(:)
    real(dp) :: cw
    real(dp) :: dp_in(2), dp_in_mat(2,1)
    integer(i4) :: i_in(2)
    integer(i4) :: xl, xu, yl, yu

    call coarse%init(nx=2, ny=1, cellsize=2.0_dp, coordsys=cartesian, y_direction=bottom_up)
    call fine%init(nx=4, ny=1, cellsize=1.0_dp, coordsys=cartesian, y_direction=bottom_up)
    call scaler%init(coarse, fine, downscaling_operator=down_split)

    dp_in = [2.0_dp, 6.0_dp]
    dp_in_mat = reshape(dp_in, [2,1])
    i_in = [1_i4, 3_i4]
    allocate(dp_out(fine%ncells), i_out(fine%ncells))

    call scaler%downscale_nearest(dp_in, dp_out)
    @assertEqual(dp_out, [2.0_dp, 2.0_dp, 6.0_dp, 6.0_dp], tolerance=1.0e-12_dp)

    call scaler%execute(dp_in, dp_out, downscaling_operator=down_nearest)
    @assertEqual(dp_out, [2.0_dp, 2.0_dp, 6.0_dp, 6.0_dp], tolerance=1.0e-12_dp)

    call scaler%execute(dp_in, dp_out, downscaling_operator=down_split)
    @assertEqual(dp_out, [1.0_dp, 1.0_dp, 3.0_dp, 3.0_dp], tolerance=1.0e-12_dp)

    call scaler%downscale_nearest(dp_in_mat, dp_out)
    @assertEqual(dp_out(2), 2.0_dp, tolerance=1.0e-12_dp)

    call scaler%downscale_nearest(i_in, i_out)
    @assertEqual(i_out, [1_i4, 1_i4, 3_i4, 3_i4])

    call scaler%execute(i_in, i_out, downscaling_operator=down_nearest)
    @assertEqual(i_out, [1_i4, 1_i4, 3_i4, 3_i4])

    call scaler%coarse_bounds(coarse_i=1, coarse_j=1, x_lb=xl, x_ub=xu, y_lb=yl, y_ub=yu)
    @assertEqual([xl, xu, yl, yu], [1_i4, 2_i4, 1_i4, 1_i4])

    call scaler%downscale_split(dp_in_mat, dp_out)
    cw = scaler%coarse_weights(1)
    @assertEqual(dp_out(1:2), [cw*dp_in_mat(1,1), cw*dp_in_mat(1,1)], tolerance=1.0e-12_dp)

    call scaler%downscale_split(dp_in, dp_out)
    @assertEqual(dp_out(1), cw*dp_in(1), tolerance=1.0e-12_dp)
  end subroutine test_downscale_modes

  @test
  subroutine test_no_scaling_identity()
    implicit none
    type(grid_t), target :: g1, g2
    type(scaler_t) :: scaler
    real(dp) :: data_mat(2,2)
    real(dp), allocatable :: packed_in(:), packed_out(:), unpacked(:,:)

    call g1%init(nx=2, ny=2, cellsize=1.0_dp, coordsys=cartesian, y_direction=bottom_up)
    call g2%init(nx=2, ny=2, cellsize=1.0_dp, coordsys=cartesian, y_direction=bottom_up)
    call scaler%init(g1, g2)

    data_mat = reshape([1.0_dp, 2.0_dp, 3.0_dp, 4.0_dp], [2,2])
    packed_in = g1%pack(data_mat)
    allocate(packed_out(size(packed_in)))
    call scaler%execute(packed_in, packed_out)
    allocate(unpacked(2,2))
    call g2%unpack_into(packed_out, unpacked)

    @assertEqual(unpacked, data_mat, tolerance=1.0e-12_dp)
  end subroutine test_no_scaling_identity

  @test
  subroutine test_stats_and_weight_count()
    implicit none
    type(grid_t), target :: fine, coarse
    type(scaler_t) :: scaler
    real(dp) :: data(2,2)
    integer(i4) :: idata(2,2)
    real(dp), allocatable :: out(:), out_mat(:,:)
    real(dp), allocatable :: out_mat2(:,:)
    integer(i4), allocatable :: iout(:), i_mat(:,:)
    integer(i4) :: ci, cj
    real(dp), allocatable :: packed_dp(:)
    integer(i4), allocatable :: packed_i(:)

    call fine%init(nx=2, ny=2, cellsize=1.0_dp, coordsys=cartesian, y_direction=bottom_up)
    call coarse%init(nx=1, ny=1, cellsize=2.0_dp, coordsys=cartesian, y_direction=bottom_up)
    call scaler%init(fine, coarse, weight_mode=1_i4) ! weight_count

    data = reshape([1.0_dp, 2.0_dp, 3.0_dp, 4.0_dp], [2,2])
    idata = reshape([1_i4, 2_i4, 3_i4, 4_i4], [2,2])
    allocate(out(coarse%ncells))
    @assertEqual(scaler%coarse_weights(1), 0.25_dp, tolerance=1.0e-12_dp)

    call scaler%execute(data, out, upscaling_operator=7_i4) ! up_var
    @assertEqual(out(1), 1.25_dp, tolerance=1.0e-12_dp)

    call scaler%execute(data, out, upscaling_operator=8_i4) ! up_std
    @assertEqual(out(1), sqrt(1.25_dp), tolerance=1.0e-12_dp)

    call scaler%execute(data, out, upscaling_operator=up_median)
    @assertEqual(out(1), 2.5_dp, tolerance=1.0e-12_dp)

    allocate(iout(coarse%ncells))
    call scaler%execute(idata, iout, upscaling_operator=up_min)
    @assertEqual(iout(1), 1_i4)
    call scaler%execute(idata, iout, upscaling_operator=up_max)
    @assertEqual(iout(1), 4_i4)
    call scaler%execute(idata, iout, upscaling_operator=up_sum)
    @assertEqual(10.0_dp, real(iout(1), dp), tolerance=1.0e-12_dp)

    allocate(out_mat(coarse%nx, coarse%ny))
    call scaler%execute(idata, out_mat, upscaling_operator=up_a_mean)
    @assertEqual(2.5_dp, out_mat(1,1), tolerance=1.0e-12_dp)

    allocate(out_mat2(coarse%nx, coarse%ny))
    call scaler%execute(data, out_mat2) ! dp 2d -> 2d
    @assertEqual(out_mat2(1,1), 2.5_dp, tolerance=1.0e-12_dp)

    packed_dp = fine%pack(data)
    call scaler%execute(packed_dp, out_mat2) ! dp 1d -> 2d
    @assertEqual(out_mat2(1,1), 2.5_dp, tolerance=1.0e-12_dp)

    allocate(i_mat(coarse%nx, coarse%ny))
    packed_i = fine%pack(idata)
    call scaler%execute(packed_i, i_mat, upscaling_operator=up_sum) ! i4 1d -> 2d
    @assertEqual(i_mat(1,1), 10_i4)

    call scaler%execute(packed_i, out_mat2, upscaling_operator=up_sum) ! i4 -> dp 2d
    @assertEqual(out_mat2(1,1), 10.0_dp, tolerance=1.0e-12_dp)

    call scaler%execute(packed_i, out_mat2, upscaling_operator=up_median) ! i4 -> dp 2d
    @assertEqual(out_mat2(1,1), 2.5_dp, tolerance=1.0e-12_dp)

    call scaler%coarse_ij(fine_i=2_i4, fine_j=1_i4, coarse_i=ci, coarse_j=cj)
    @assertEqual([ci, cj], [1_i4, 1_i4])
  end subroutine test_stats_and_weight_count

  @test
  subroutine test_median_masked()
    implicit none
    type(grid_t), target :: fine, coarse
    type(scaler_t) :: scaler
    logical :: mask(4,2)
    real(dp) :: data(4,2)
    integer(i4) :: idata(4,2)
    real(dp), allocatable :: out(:)

    mask = .false.
    mask(2,1) = .true.
    mask(3,1) = .true.
    mask(4,1) = .true.

    call fine%init(nx=4, ny=2, cellsize=1.0_dp, coordsys=cartesian, y_direction=bottom_up, mask=mask)
    call coarse%init(nx=2, ny=1, cellsize=2.0_dp, coordsys=cartesian, y_direction=bottom_up)
    call scaler%init(fine, coarse)

    data = reshape([ &
      10.0_dp, 20.0_dp, 3.0_dp, 4.0_dp, &
      30.0_dp, 40.0_dp, 100.0_dp, 200.0_dp &
    ], [4,2])
    idata = nint(data, i4)
    allocate(out(coarse%ncells))

    call scaler%execute(data, out, upscaling_operator=up_median)
    @assertEqual(out(1), 20.0_dp, tolerance=1.0e-12_dp)
    @assertEqual(out(2), 3.5_dp, tolerance=1.0e-12_dp)

    call scaler%execute(idata, out, upscaling_operator=up_median)
    @assertEqual(out(1), 20.0_dp, tolerance=1.0e-12_dp)
    @assertEqual(out(2), 3.5_dp, tolerance=1.0e-12_dp)
  end subroutine test_median_masked

  @test
  subroutine test_laf_masked_direct_and_packed()
    implicit none
    type(grid_t), target :: fine, coarse
    type(scaler_t) :: scaler
    logical :: mask(2,2)
    integer(i4) :: idata(2,2)
    integer(i4), allocatable :: out(:), packed_i(:)

    mask = .false.
    mask(1,1) = .true.

    call fine%init(nx=2, ny=2, cellsize=1.0_dp, coordsys=cartesian, y_direction=bottom_up, mask=mask)
    call coarse%init(nx=1, ny=1, cellsize=2.0_dp, coordsys=cartesian, y_direction=bottom_up)
    call scaler%init(fine, coarse)

    idata = reshape([1_i4, 2_i4, 2_i4, 2_i4], [2,2])
    allocate(out(coarse%ncells))

    call scaler%execute(idata, out, upscaling_operator=up_laf, vmin=1_i4, vmax=2_i4)
    @assertEqual(out(1), 1_i4)

    packed_i = fine%pack(idata)
    call scaler%execute(packed_i, out, upscaling_operator=up_laf, vmin=1_i4, vmax=2_i4)
    @assertEqual(out(1), 1_i4)
  end subroutine test_laf_masked_direct_and_packed

  @test
  subroutine test_nearest_regridder_cartesian()
    implicit none
    type(grid_t), target :: source, target
    type(nearest_regridder_t) :: regridder
    real(dp) :: dp_in(2), dp_in_mat(2,1), dp_out(3), dp_out_mat(3,1)
    integer(i4) :: i_in(2), i_in_mat(2,1), i_out(3), i_out_mat(3,1)

    call source%init(nx=2, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=2.0_dp, &
                     coordsys=cartesian, y_direction=bottom_up)
    call target%init(nx=3, ny=1, xllcorner=0.4_dp, yllcorner=0.0_dp, cellsize=0.75_dp, &
                     coordsys=cartesian, y_direction=bottom_up)

    call regridder%init(source, target)

    dp_in = [10.0_dp, 20.0_dp]
    dp_in_mat = reshape(dp_in, [2, 1])
    i_in = [1_i4, 2_i4]
    i_in_mat = reshape(i_in, [2, 1])

    call regridder%execute(dp_in, dp_out)
    @assertEqual(dp_out, [10.0_dp, 10.0_dp, 20.0_dp], tolerance=1.0e-12_dp)

    call regridder%execute(dp_in_mat, dp_out_mat)
    @assertEqual(dp_out_mat(:,1), [10.0_dp, 10.0_dp, 20.0_dp], tolerance=1.0e-12_dp)

    call regridder%execute(i_in, i_out)
    @assertEqual(i_out, [1_i4, 1_i4, 2_i4])

    call regridder%execute(i_in_mat, i_out_mat)
    @assertEqual(i_out_mat(:,1), [1_i4, 1_i4, 2_i4])
  end subroutine test_nearest_regridder_cartesian

  @test
  subroutine test_nearest_regridder_masked_and_aux()
    implicit none
    type(grid_t), target :: source_masked, target_near, source_plain, target_masked, source_aux, target_aux
    type(nearest_regridder_t) :: masked_regridder, target_regridder, aux_regridder
    logical :: source_mask(3,1), target_mask(3,1)
    real(dp) :: masked_out(1), target_out(3,1), aux_out(2)

    source_mask = .true.
    source_mask(2,1) = .false.
    call source_masked%init(nx=3, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                            coordsys=cartesian, y_direction=bottom_up, mask=source_mask)
    call target_near%init(nx=1, ny=1, xllcorner=1.1_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                          coordsys=cartesian, y_direction=bottom_up)
    call masked_regridder%init(source_masked, target_near)
    call masked_regridder%execute([10.0_dp, 30.0_dp], masked_out)
    @assertEqual(masked_out(1), 30.0_dp, tolerance=1.0e-12_dp)

    target_mask = .true.
    target_mask(2,1) = .false.
    call source_plain%init(nx=2, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                           coordsys=cartesian, y_direction=bottom_up)
    call target_masked%init(nx=3, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                            coordsys=cartesian, y_direction=bottom_up, mask=target_mask)
    call target_regridder%init(source_plain, target_masked)
    call target_regridder%execute([1.0_dp, 2.0_dp], target_out)
    @assertEqual(target_out(1,1), 1.0_dp, tolerance=1.0e-12_dp)
    @assertEqual(target_out(2,1), nodata_dp, tolerance=1.0e-12_dp)
    @assertEqual(target_out(3,1), 2.0_dp, tolerance=1.0e-12_dp)

    call source_aux%init(nx=2, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                         coordsys=cartesian, y_direction=bottom_up)
    call target_aux%init(nx=2, ny=1, xllcorner=10.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                         coordsys=cartesian, y_direction=bottom_up)
    allocate(source_aux%lon(source_aux%nx, source_aux%ny), source_aux%lat(source_aux%nx, source_aux%ny))
    allocate(target_aux%lon(target_aux%nx, target_aux%ny), target_aux%lat(target_aux%nx, target_aux%ny))
    source_aux%lon(:,1) = [0.0_dp, 10.0_dp]
    source_aux%lat(:,1) = [0.0_dp, 0.0_dp]
    target_aux%lon(:,1) = [9.0_dp, 1.0_dp]
    target_aux%lat(:,1) = [0.0_dp, 0.0_dp]

    call aux_regridder%init(source_aux, target_aux, use_aux=.true.)
    call aux_regridder%execute([10.0_dp, 20.0_dp], aux_out)
    @assertEqual(aux_out, [20.0_dp, 10.0_dp], tolerance=1.0e-12_dp)
  end subroutine test_nearest_regridder_masked_and_aux

  @test
  subroutine test_nearest_regridder_spherical_and_mixed()
    implicit none
    type(grid_t), target :: source_sph, target_sph, target_cart_aux
    type(nearest_regridder_t) :: sph_regridder, mixed_regridder
    real(dp) :: sph_out(1), mixed_out(2)

    call source_sph%init(nx=4, ny=1, xllcorner=0.0_dp, yllcorner=-45.0_dp, cellsize=90.0_dp, &
                         coordsys=spherical, y_direction=bottom_up)
    call target_sph%init(nx=1, ny=1, xllcorner=330.0_dp, yllcorner=-20.0_dp, cellsize=40.0_dp, &
                         coordsys=spherical, y_direction=bottom_up)
    call sph_regridder%init(source_sph, target_sph)
    call sph_regridder%execute([1.0_dp, 2.0_dp, 3.0_dp, 4.0_dp], sph_out)
    @assertEqual(sph_out(1), 4.0_dp, tolerance=1.0e-12_dp)

    call target_cart_aux%init(nx=2, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                              coordsys=cartesian, y_direction=bottom_up)
    allocate(target_cart_aux%lon(target_cart_aux%nx, target_cart_aux%ny), &
             target_cart_aux%lat(target_cart_aux%nx, target_cart_aux%ny))
    target_cart_aux%lon(:,1) = [44.0_dp, 316.0_dp]
    target_cart_aux%lat(:,1) = [0.0_dp, 0.0_dp]

    call mixed_regridder%init(source_sph, target_cart_aux)
    call mixed_regridder%execute([1.0_dp, 2.0_dp, 3.0_dp, 4.0_dp], mixed_out)
    @assertEqual(mixed_out, [1.0_dp, 4.0_dp], tolerance=1.0e-12_dp)
  end subroutine test_nearest_regridder_spherical_and_mixed

  @test
  subroutine test_nearest_regridder_derived_mask_cartesian()
    implicit none
    type(grid_t), target :: source_masked, target_mid, source_small, target_wide, source_and, target_and, &
                            source_all_masked, target_empty, target_area
    type(nearest_regridder_t) :: derived_regridder, outside_regridder, and_regridder, empty_regridder, area_regridder
    logical :: source_mask(3,1), source_and_mask(3,1), target_and_mask(3,1), all_mask(2,1)
    real(dp) :: target_out(3,1), outside_out(4,1), and_out(3,1), empty_out(2,1), target_packed(2), outside_packed(2)
    real(dp), allocatable :: empty_in(:)

    source_mask = .true.
    source_mask(2,1) = .false.
    call source_masked%init(nx=3, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                            coordsys=cartesian, y_direction=bottom_up, mask=source_mask)

    call target_mid%init(nx=3, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                         coordsys=cartesian, y_direction=bottom_up)
    call derived_regridder%init(source_masked, target_mid, derive_target_mask=.true.)
    @assertEqual(target_mid%ncells, 2_i8)
    @assertTrue(all(target_mid%mask(:,1) .eqv. [.true., .false., .true.]))
    call derived_regridder%execute([10.0_dp, 30.0_dp], target_packed)
    @assertEqual(target_packed, [10.0_dp, 30.0_dp], tolerance=1.0e-12_dp)
    call derived_regridder%execute([10.0_dp, 30.0_dp], target_out)
    @assertEqual(target_out(1,1), 10.0_dp, tolerance=1.0e-12_dp)
    @assertEqual(target_out(2,1), nodata_dp, tolerance=1.0e-12_dp)
    @assertEqual(target_out(3,1), 30.0_dp, tolerance=1.0e-12_dp)

    call source_small%init(nx=2, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                           coordsys=cartesian, y_direction=bottom_up)
    call target_wide%init(nx=4, ny=1, xllcorner=-1.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                          coordsys=cartesian, y_direction=bottom_up)
    call outside_regridder%init(source_small, target_wide, derive_target_mask=.true.)
    @assertEqual(target_wide%ncells, 2_i8)
    @assertTrue(all(target_wide%mask(:,1) .eqv. [.false., .true., .true., .false.]))
    call outside_regridder%execute([10.0_dp, 20.0_dp], outside_packed)
    @assertEqual(outside_packed, [10.0_dp, 20.0_dp], tolerance=1.0e-12_dp)
    call outside_regridder%execute([10.0_dp, 20.0_dp], outside_out)
    @assertEqual(outside_out(1,1), nodata_dp, tolerance=1.0e-12_dp)
    @assertEqual(outside_out(2,1), 10.0_dp, tolerance=1.0e-12_dp)
    @assertEqual(outside_out(3,1), 20.0_dp, tolerance=1.0e-12_dp)
    @assertEqual(outside_out(4,1), nodata_dp, tolerance=1.0e-12_dp)

    source_and_mask(:,1) = [.false., .true., .true.]
    target_and_mask(:,1) = [.true., .false., .true.]
    call source_and%init(nx=3, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                         coordsys=cartesian, y_direction=bottom_up, mask=source_and_mask)
    call target_and%init(nx=3, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                         coordsys=cartesian, y_direction=bottom_up, mask=target_and_mask)
    call and_regridder%init(source_and, target_and, derive_target_mask=.true.)
    @assertEqual(target_and%ncells, 1_i8)
    @assertTrue(all(target_and%mask(:,1) .eqv. [.false., .false., .true.]))
    call and_regridder%execute([20.0_dp, 30.0_dp], and_out)
    @assertEqual(and_out(1,1), nodata_dp, tolerance=1.0e-12_dp)
    @assertEqual(and_out(2,1), nodata_dp, tolerance=1.0e-12_dp)
    @assertEqual(and_out(3,1), 30.0_dp, tolerance=1.0e-12_dp)

    call target_area%init(nx=3, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                          coordsys=cartesian, y_direction=bottom_up)
    target_area%cell_area = [1.0_dp, 2.0_dp, 3.0_dp]
    call area_regridder%init(source_masked, target_area, derive_target_mask=.true.)
    @assertEqual(target_area%ncells, 2_i8)
    @assertEqual(target_area%cell_area, [1.0_dp, 3.0_dp], tolerance=1.0e-12_dp)

    all_mask = .false.
    call source_all_masked%init(nx=2, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                                coordsys=cartesian, y_direction=bottom_up, mask=all_mask)
    call target_empty%init(nx=2, ny=1, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                           coordsys=cartesian, y_direction=bottom_up)
    call empty_regridder%init(source_all_masked, target_empty, derive_target_mask=.true.)
    @assertEqual(target_empty%ncells, 0_i8)
    @assertTrue(all(.not. target_empty%mask(:,1)))
    allocate(empty_in(0))
    call empty_regridder%execute(empty_in, empty_out)
    @assertEqual(empty_out(1,1), nodata_dp, tolerance=1.0e-12_dp)
    @assertEqual(empty_out(2,1), nodata_dp, tolerance=1.0e-12_dp)
  end subroutine test_nearest_regridder_derived_mask_cartesian

  @test
  subroutine test_nearest_regridder_derived_mask_spherical_aux()
    implicit none
    type(grid_t), target :: source_sph_masked, target_sph, source_aux_masked, target_aux
    type(nearest_regridder_t) :: sph_mask_regridder, aux_mask_regridder
    logical :: sph_mask(4,1), aux_mask(2,2)
    real(dp) :: sph_out(1,1), aux_out(2,1)

    sph_mask = .true.
    sph_mask(4,1) = .false.
    call source_sph_masked%init(nx=4, ny=1, xllcorner=0.0_dp, yllcorner=-45.0_dp, cellsize=90.0_dp, &
                                coordsys=spherical, y_direction=bottom_up, mask=sph_mask)
    call target_sph%init(nx=1, ny=1, xllcorner=330.0_dp, yllcorner=-20.0_dp, cellsize=40.0_dp, &
                         coordsys=spherical, y_direction=bottom_up)
    call sph_mask_regridder%init(source_sph_masked, target_sph, derive_target_mask=.true.)
    @assertEqual(target_sph%ncells, 0_i8)
    call sph_mask_regridder%execute([1.0_dp, 2.0_dp, 3.0_dp], sph_out)
    @assertEqual(sph_out(1,1), nodata_dp, tolerance=1.0e-12_dp)

    aux_mask = reshape([.true., .false., .true., .true.], [2, 2])
    call source_aux_masked%init(nx=2, ny=2, xllcorner=0.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                                coordsys=cartesian, y_direction=bottom_up, mask=aux_mask)
    call target_aux%init(nx=2, ny=1, xllcorner=10.0_dp, yllcorner=0.0_dp, cellsize=1.0_dp, &
                         coordsys=cartesian, y_direction=bottom_up)
    allocate(source_aux_masked%lon(source_aux_masked%nx, source_aux_masked%ny), &
             source_aux_masked%lat(source_aux_masked%nx, source_aux_masked%ny))
    allocate(target_aux%lon(target_aux%nx, target_aux%ny), target_aux%lat(target_aux%nx, target_aux%ny))
    source_aux_masked%lon = reshape([0.5_dp, 1.5_dp, 0.5_dp, 1.5_dp], [2, 2])
    source_aux_masked%lat = reshape([0.5_dp, 0.5_dp, 1.5_dp, 1.5_dp], [2, 2])
    target_aux%lon(:,1) = [1.5_dp, 0.5_dp]
    target_aux%lat(:,1) = [0.5_dp, 1.5_dp]

    call aux_mask_regridder%init(source_aux_masked, target_aux, use_aux=.true., derive_target_mask=.true.)
    @assertTrue(source_aux_masked%has_aux_vertices())
    @assertEqual(target_aux%ncells, 1_i8)
    @assertTrue(all(target_aux%mask(:,1) .eqv. [.false., .true.]))
    call aux_mask_regridder%execute([10.0_dp, 20.0_dp, 30.0_dp], aux_out)
    @assertEqual(aux_out(1,1), nodata_dp, tolerance=1.0e-12_dp)
    @assertEqual(aux_out(2,1), 20.0_dp, tolerance=1.0e-12_dp)
  end subroutine test_nearest_regridder_derived_mask_spherical_aux

end module test_mo_grid_scaler
