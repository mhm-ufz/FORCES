module test_mo_grid_io
  use funit
  implicit none

  private

  public :: test_output, test_output_cache, test_output_cache_static_contiguous

contains

  @test
  subroutine test_output()
    call run_output_case("height.nc")
  end subroutine test_output

  @test
  subroutine test_output_cache()
    use mo_kind, only: i4
    implicit none
    call run_output_case("height_cache.nc", cache_size=16_i4)
  end subroutine test_output_cache

  @test
  subroutine test_output_cache_static_contiguous()
    use mo_kind, only: i4
    implicit none
    call run_output_case("height_cache_static.nc", cache_size=16_i4, static_contiguous=.true.)
  end subroutine test_output_cache_static_contiguous

  subroutine run_output_case(outfile, cache_size, static_contiguous)
    use mo_kind, only: dp, i4, sp, i8
    use mo_grid, only: grid_t
    use mo_grid_io, only: var, output_dataset, center_timestamp, time_units_delta, daily, input_dataset
    use mo_datetime, only: datetime, timedelta
    implicit none
    character(*), intent(in) :: outfile
    integer(i4), intent(in), optional :: cache_size
    logical, intent(in), optional :: static_contiguous
    type(datetime) :: start_time, end_time, current_time, ref_time
    type(timedelta) :: model_step
    type(grid_t), target :: grid, grd2
    type(output_dataset) :: out_ds
    type(input_dataset) :: in_ds
    type(datetime), allocatable :: times(:)
    real(dp), allocatable :: dem(:,:), height(:), heights(:), dem_read(:,:), height_read(:), h_chunk(:,:)
    real(sp), allocatable :: dem_sp(:,:)
    integer(i4), allocatable :: dem_i4(:,:), dem_int_read(:,:), height_i4(:)
    integer(i8), allocatable :: dem_i8(:,:)

    type(var), allocatable :: vars(:), in_vars(:)
    type(var) :: out_dem_meta, out_height_meta, in_dem_meta, in_height_meta
    real(dp) :: factor
    integer(i4) :: write_step
    character(:), allocatable :: delta
    real(dp) :: t=1.0E-5_dp

    ! model time config
    start_time = datetime("2025-01-01")
    end_time = datetime("2025-01-15")
    ref_time = datetime("1970-01-01")
    model_step = timedelta(hours=1_i4)

    ! output time config
    write_step = daily
    delta = time_units_delta(write_step, center_timestamp)

    ! initialize grid from DEM ascii file
    call grid%from_ascii_file("./files/dem.asc")
    call grid%read_data("./files/dem.asc", dem)
    height = grid%pack(dem)
    height_i4 = grid%pack(nint(dem, i4))

    allocate(vars(0))
    vars = [vars, var(name="dem", units="m", static=.true., allow_static=.true., dtype="f32", kind="dp")]
    vars = [vars, var(name="dem_int", units="m", static=.true., allow_static=.true., dtype="i32", kind="i4")]
    vars = [vars, var(name="height", units="m", avg=.true., static=.false., allow_static=.true.)]
    allocate(in_vars(0))
    in_vars = [in_vars, var(name="dem", units="m", static=.false., allow_static=.true., dtype="f32", kind="dp")]
    in_vars = [in_vars, var(name="dem_int", units="m", static=.false., allow_static=.true., dtype="i32", kind="i4")]
    in_vars = [in_vars, var(name="height", units="m", static=.false., allow_static=.true.)]
    if (present(cache_size)) then
      if (present(static_contiguous)) then
        call out_ds%init( &
          & path=outfile, &
          & grid=grid, &
          & vars=vars, &
          & start_time=start_time, &
          & ref_time=ref_time, &
          & delta=delta, &
          & timestamp=center_timestamp, &
          & cache_size=cache_size, &
          & static_contiguous=static_contiguous)
      else
        call out_ds%init( &
          & path=outfile, &
          & grid=grid, &
          & vars=vars, &
          & start_time=start_time, &
          & ref_time=ref_time, &
          & delta=delta, &
          & timestamp=center_timestamp, &
          & cache_size=cache_size)
      end if
    else
      call out_ds%init( &
        & path=outfile, &
        & grid=grid, &
        & vars=vars, &
        & start_time=start_time, &
        & ref_time=ref_time, &
        & delta=delta, &
        & timestamp=center_timestamp)
    end if
    out_dem_meta = out_ds%meta("dem")
    out_height_meta = out_ds%meta("height")
    @assertTrue(out_dem_meta%static, message='output meta keeps static flag')
    @assertFalse(out_dem_meta%allow_static, message='output should ignore allow_static')
    @assertFalse(out_height_meta%static, message='output meta keeps temporal flag')
    @assertFalse(out_height_meta%allow_static, message='output should ignore allow_static')

    call out_ds%update("dem", height)
    call out_ds%update("dem_int", height_i4)
    call out_ds%write_static()

    ! model time loop
    current_time = start_time
    factor = 0.0_dp
    allocate(heights(grid%ncells), source=0.0_dp)
    do while(current_time < end_time)
      factor = factor + 0.01_dp
      if (current_time%date()==datetime("2025-01-10")) heights = heights + height * cos(factor)
      current_time = current_time + model_step
      call out_ds%update("height", height * cos(factor))
      if (current_time%is_new_day()) call out_ds%write(current_time)
    end do
    call out_ds%close()

    heights = heights / 24.0_dp

    call grd2%from_netcdf(outfile, "height")
    @assertEqual(grid%ncells, grd2%ncells, message='ncells compare')
    @assertEqual(grid%nx, grd2%nx, message='nx compare')
    @assertEqual(grid%ny, grd2%ny, message='ny compare')
    @assertEqual(grid%xllcorner, grd2%xllcorner, tolerance=t, message='xllcorner compare')
    @assertEqual(grid%yllcorner, grd2%yllcorner, tolerance=t, message='yllcorner compare')

    call in_ds%init(outfile, grid=grd2, vars=in_vars)
    in_dem_meta = in_ds%meta("dem")
    in_height_meta = in_ds%meta("height")
    @assertTrue(in_dem_meta%static, message='input auto-detect static variable')
    @assertFalse(in_height_meta%static, message='input auto-detect temporal variable')
    @assertFalse(in_dem_meta%allow_static, message='input meta should not expose allow_static as file metadata')
    @assertFalse(in_height_meta%allow_static, message='input meta should not expose allow_static as file metadata')
    @assertFalse(in_ds%static, message='input dataset should detect time dimension')

    allocate(dem_read(grid%nx, grid%ny))
    allocate(dem_sp(grid%nx, grid%ny))
    allocate(dem_i4(grid%nx, grid%ny))
    allocate(dem_int_read(grid%nx, grid%ny))
    allocate(dem_i8(grid%nx, grid%ny))
    allocate(height_read(grid%ncells))
    call in_ds%read("dem", data=dem_read)
    call in_ds%read("dem", data=dem_sp)
    call in_ds%read("dem", data=dem_i4)
    call in_ds%read("dem", data=dem_i8)
    call in_ds%read("dem_int", data=dem_int_read)
    call in_ds%read("height", data=height_read, current_time=datetime("2025-01-11"))
    call in_ds%read_chunk("height", &
      timeframe_start=datetime("2025-01-10"), &
      timeframe_end=datetime("2025-01-15"), &
      times=times, data=h_chunk)
    call in_ds%close()

    @assertEqual(dem_i4, nint(dem, i4), message='static read check i4')
    @assertEqual(dem_int_read, nint(dem, i4), message='static integer output read check i4')
    @assertEqual(dem_i8, nint(dem, i8), message='static read check i8')
    @assertEqual(dem_sp, real(dem, sp), tolerance=real(t, sp), message='static read check sp')
    @assertEqual(dem_read, dem, tolerance=t, message='static read check')
    @assertEqual(height_read, heights, tolerance=t, message='temporal read check')
    @assertEqual(size(times), size(h_chunk, dim=2))
    @assertTrue(times(1)==datetime("2025-01-11"), message='checking start time frame')
    @assertTrue(times(size(Times))==datetime("2025-01-15"), message='checking end time frame')
    @assertFalse(in_ds%flip_y, "not flipping input since grid is equal")
  end subroutine run_output_case

end module test_mo_grid_io
